<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp">

        <!-- Botón de perfil arriba a la derecha -->

        <!-- Imagen central -->

        <!-- Texto "Radar" -->

        <!-- Texto secundario -->

        <!-- Texto "Mantente a salvo" -->

        <!-- Botón "Pedir ayuda" -->

        <ImageButton
            android:id="@+id/homeButton"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_gravity="start"
            android:layout_marginTop="20dp"
            android:background="#00777777"
            android:contentDescription="Botón de configuración de perfil"
            app:layout_constraintEnd_toStartOf="@+id/textView11"
            app:layout_constraintHorizontal_bias="0.151"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/vector" />

        <ImageButton
            android:id="@+id/perfilButton"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/boton_perfil"
            android:contentDescription="Botón de configuración de perfil"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.822"
            app:layout_constraintStart_toEndOf="@+id/textView11"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/icon_park_outline_user" />

        <TextView
            android:id="@+id/textView11"
            android:layout_width="111dp"
            android:layout_height="38dp"
            android:layout_marginTop="36dp"
            android:fontFamily="@font/verdanabold"
            android:text="@string/Radar"
            android:textColor="@color/azul"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/helpButton"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:background="@drawable/boton_rojo"
            android:fontFamily="@font/verdanabold"
            android:text="@string/pedir_ayuda"
            android:textColor="@color/blanco_texto"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView11"
            app:layout_constraintVertical_bias="0.922" />

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="309dp"
            android:layout_height="74dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/rounded_button"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

                <!-- Botón Biblioteca -->

                <!-- Botón Radar -->
                <ImageButton
                    android:id="@+id/bibliotecaButton"
                    android:layout_width="150dp"
                    android:layout_height="70dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Biblioteca"
                    android:src="@drawable/icono_biblioteca" />

                <ImageButton
                    android:id="@+id/radarButton"
                    android:layout_width="150dp"
                    android:layout_height="70dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Radar"
                    android:src="@drawable/radar_selected" />

        </LinearLayout>

        <RelativeLayout
            android:layout_width="412dp"
            android:layout_height="412dp"
            app:layout_constraintBottom_toTopOf="@+id/helpButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.515"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0">

                <!-- Círculo principal centrado -->
                <ImageView
                    android:id="@+id/phone1"
                    android:layout_width="53dp"
                    android:layout_height="16dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/cel_1radar" />

                <!-- Círculo 1 alrededor -->
                <ImageView
                    android:id="@+id/circle1"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_2" />

                <!-- Círculo 2 más grande -->
                <ImageView
                    android:id="@+id/circle2"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_3" />

                <!-- Círculo 3 aún más grande -->
                <ImageView
                    android:id="@+id/circle3"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_4" />

                <!-- Círculo 4 aún más más grande -->

                <ImageView
                    android:id="@+id/circle4"
                    android:layout_width="310dp"
                    android:layout_height="307dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_5" />


        </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
