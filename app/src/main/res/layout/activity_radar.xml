<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp">

        <!-- Botón de perfil arriba a la derecha -->

        <!-- Imagen central -->

        <!-- Texto "Radar" -->

        <!-- Texto secundario -->

        <!-- Texto "Mantente a salvo" -->

        <!-- Botón "Pedir ayuda" -->

        <ImageButton
            android:id="@+id/homeButton"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_gravity="start"
            android:layout_marginTop="20dp"
            android:background="#00777777"
            android:contentDescription="Botón de configuración de perfil"
            app:layout_constraintEnd_toStartOf="@+id/textoRadar"
            app:layout_constraintHorizontal_bias="0.151"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/vector" />

        <ImageButton
            android:id="@+id/perfilButton"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/boton_perfil"
            android:contentDescription="Botón de configuración de perfil"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.822"
            app:layout_constraintStart_toEndOf="@+id/textoRadar"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/icon_park_outline_user" />

        <TextView
            android:id="@+id/textoRadar"
            android:layout_width="111dp"
            android:layout_height="38dp"
            android:layout_marginTop="36dp"
            android:fontFamily="@font/verdanabold"
            android:text="@string/Radar"
            android:textColor="@color/azul"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/helpButton"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:background="@drawable/boton_rojo"
            android:fontFamily="@font/verdanabold"
            android:text="@string/pedir_ayuda"
            android:textColor="@color/blanco_texto"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cajonZoom"
            android:paddingVertical="10dp"/>

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:background="@drawable/rounded_button"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

                <!-- Botón Biblioteca -->

                <!-- Botón Radar -->
                <ImageButton
                    android:id="@+id/bibliotecaButton"
                    android:layout_width="150dp"
                    android:layout_height="70dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Biblioteca"
                    android:src="@drawable/icono_biblioteca"
                    android:layout_gravity="center"/>

                <ImageButton
                    android:id="@+id/radarButton"
                    android:layout_width="150dp"
                    android:layout_height="70dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Radar"
                    android:src="@drawable/radar_selected"
                    android:layout_gravity="center"/>

        </LinearLayout>


        <LinearLayout
            android:id="@+id/cajonZoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_button"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintBottom_toTopOf="@+id/helpButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/radarArea">

                <ImageButton
                    android:id="@+id/lessZoom"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/disminuir_zoom"
                    android:src="@drawable/minus" />

                <TextView
                    android:id="@+id/textZoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/verdanabold"
                    android:paddingHorizontal="30dp"
                    android:text="100"
                    android:textColor="@color/blanco_texto"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/moreZoom"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/aumentar_zoom"
                    android:src="@drawable/plus" />

        </LinearLayout>

        <RelativeLayout
            android:id="@+id/radarArea"
            android:layout_width="412dp"
            android:layout_height="412dp"
            app:layout_constraintBottom_toTopOf="@+id/cajonZoom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.515"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textoRadar">

                <ImageView
                    android:id="@+id/circle1"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_2" />

                <ImageView
                    android:id="@+id/circle2"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_3" />

                <ImageView
                    android:id="@+id/circle3"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_4" />

                <ImageView
                    android:id="@+id/circle4"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ellipse_5" />

                <ImageView
                    android:id="@+id/phone1"
                    android:layout_width="53dp"
                    android:layout_height="16dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/cel_1radar" />

                <RelativeLayout
                    android:id="@+id/radarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                        <View
                            android:id="@+id/anchor_circle4"
                            android:layout_width="300dp"
                            android:layout_height="300dp"
                            android:layout_centerInParent="true" />

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_above="@+id/anchor_circle4"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="6dp"
                            android:contentDescription="@string/FlechaNorte"
                            android:src="@drawable/flecha_norte" />

                </RelativeLayout>
        </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
